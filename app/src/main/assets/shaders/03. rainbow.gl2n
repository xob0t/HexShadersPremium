uniform vec3      iResolution;           // viewport resolution (in pixels)
uniform float     iGlobalTime;           // shader playback time (in seconds)
uniform float     iTimeDelta;            // render time (in seconds)
uniform int       iFrame;                // shader playback frame
uniform vec4      iMouse;                // mouse pixel coords. xy: current (if MLB down), zw: click

uniform mediump float u_offset;
attribute mediump vec2 a_pos;
attribute mediump vec2 t_pos;
varying lowp vec4 v_col;

vec2 fragCoord;
// $cprt|http://xdpixel.com/colorful-voronoi|Copyright|Brandon Fogerty|skip$

/// -----------------------------
/// $pointsInTheRow|64|Range|Detail level;16;128|skip$
/// $slides|1|Range|Slide show (battery save);1;11|skip$
/// $timeScale|10|Range|Time scale;1;40|skip$
    #define iTime iGlobalTime * 0.05
/// -----------------------------
/// shader code before MAIN

vec2 hash(vec2 p)
{
    mat2 m = mat2(  13.85, 47.77,
                    99.41, 88.48
                );

    return fract(sin(m*p) * 46738.29);
}

float voronoi(vec2 p)
{
    vec2 g = floor(p);
    vec2 f = fract(p);

    float distanceToClosestFeaturePoint = 1.0;
    for(int y = -1; y <= 1; y++)
    {
        for(int x = -1; x <= 1; x++)
        {
            vec2 latticePoint = vec2(x, y);
            float currentDistance = distance(latticePoint + hash(g+latticePoint), f);
            distanceToClosestFeaturePoint = min(distanceToClosestFeaturePoint, currentDistance);
        }
    }

    return distanceToClosestFeaturePoint;
}

void main()
{
    vec2 uv = a_pos;
    uv.x *= iResolution.x/iResolution.y;

    float offset = voronoi(uv*10.0 + vec2(iTime));
    float t = 1.0/abs(((uv.x + sin(uv.y + iTime)) + offset) * 30.0);

    float r = voronoi( uv * 1.0 ) * (15.0+5.0*sin(iTime));
    vec3 finalColor = vec3(12.0 * uv.y, 2.0, 1.0 * r) * t;
    
    v_col = vec4(finalColor, 1.0 );
	
    gl_PointSize = 1.0;
    gl_Position.xy = t_pos * 2.0 - 1.0;
    gl_Position.zw = vec2(1.0);
}

====
// fragment shader
varying lowp vec4 v_col;

void main()
{
	gl_FragColor = v_col;
}
